# ThingSpeak Channel Feed (optional). Leave empty to use built-in demo data.
VITE_THINGSPEAK_CHANNEL_ID=

# Read API key — only if the channel is private.
VITE_THINGSPEAK_READ_API_KEY=

# Poll interval for live feeds (ms), minimum 5000. Default 30000.
VITE_THINGSPEAK_POLL_MS=30000

# Consider data stale if last feed is older than this (ms). Default 300000 (5 min).
VITE_THINGSPEAK_STALE_MS=300000

# How many feed rows to fetch (ThingSpeak `results`). Min 1, max 8000. Default 60.
VITE_THINGSPEAK_RESULTS=60

# Field mapping (fixed in src/config/channelFields.ts):
#   field1 → Salinity %
#   field2 → Tide level
#   field3 → Status (>= 0.5 = OK)
#   field4 → Carbon (display units as configured on channel)
